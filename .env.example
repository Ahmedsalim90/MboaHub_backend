APP_NAME=Ecosystem API
ENVIRONMENT=local
DATABASE_URL=postgresql+asyncpg://ecosystem:ecosystem@localhost:5432/ecosystem
REDIS_URL=redis://localhost:6379/0
JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30
CORS_ORIGINS=["http://localhost:5173"]

CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

STRIPE_WEBHOOK_SECRET=
MOMO_WEBHOOK_SECRET=

# Register a normal account with this email, then restart the app once -
# it will be auto-promoted to ADMIN. Leave empty to disable.
ADMIN_BOOTSTRAP_EMAIL=
